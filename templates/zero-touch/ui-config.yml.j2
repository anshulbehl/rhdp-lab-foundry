---
# Showroom UI Configuration for {{ lab_name }}
# Generated by Lab Foundry

antora:
  modules:
{% for module in modules %}
    - name: {{ module.id }}
      title: "{{ module.title }}"
{% endfor %}

tabs:
  - name: Terminal
    url: terminal
    type: terminal

{% for tab in tabs | default([]) %}
  - name: {{ tab.name }}
    url: {{ tab.url }}
{% if tab.new_tab is defined and tab.new_tab %}
    new_tab: true
{% endif %}
{% endfor %}
