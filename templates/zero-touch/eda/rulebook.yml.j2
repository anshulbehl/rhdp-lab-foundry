---
# EDA Rulebook for {{ lab_name }}
# Generated by Lab Foundry
#
# This rulebook listens for events and triggers AAP job templates
# in response. Customize the source, conditions, and actions below.
#
# See foundry/references/zt-zero-trust-aap.md for the Splunk incident
# response pattern this is based on.

- name: {{ eda_rulebook_name | default(lab_name + ' Event Handler') }}
  hosts: all

  sources:
{% if eda_source_type == 'webhook' %}
    - ansible.eda.webhook:
        host: 0.0.0.0
        port: {{ eda_webhook_port | default(5000) }}
{% elif eda_source_type == 'alertmanager' %}
    - ansible.eda.alertmanager:
        host: 0.0.0.0
        port: {{ eda_alertmanager_port | default(8000) }}
{% elif eda_source_type == 'kafka' %}
    - ansible.eda.kafka:
        host: {{ eda_kafka_host | default('kafka') }}
        port: {{ eda_kafka_port | default(9092) }}
        topic: {{ eda_kafka_topic | default('lab-events') }}
        group_id: {{ eda_kafka_group | default('eda-consumer') }}
{% elif eda_source_type == 'pg_listener' %}
    - ansible.eda.pg_listener:
        host: {{ eda_pg_host | default('localhost') }}
        port: {{ eda_pg_port | default(5432) }}
        dbname: {{ eda_pg_dbname | default('events') }}
        channels:
          - {{ eda_pg_channel | default('lab_events') }}
{% endif %}

  rules:
{% for rule in eda_rules | default([]) %}
    - name: {{ rule.name }}
      condition: {{ rule.condition }}
{% if rule.action == 'run_job_template' %}
      action:
        run_job_template:
          name: "{{ rule.job_template_name }}"
          organization: "{{ rule.organization | default('Default') }}"
{% if rule.extra_vars is defined %}
          job_args:
            extra_vars: {{ rule.extra_vars }}
{% endif %}
{% elif rule.action == 'run_playbook' %}
      action:
        run_playbook:
          name: "{{ rule.playbook_name }}"
{% if rule.extra_vars is defined %}
          extra_vars: {{ rule.extra_vars }}
{% endif %}
{% elif rule.action == 'debug' %}
      action:
        debug:
          msg: "{{ rule.message | default('Event received') }}"
{% endif %}

{% endfor %}
{% if not eda_rules %}
    - name: Handle incoming event
      condition: event.payload is defined
      action:
        run_job_template:
          name: "{{ eda_default_job_template | default('Respond to Event') }}"
          organization: "Default"
{% endif %}
