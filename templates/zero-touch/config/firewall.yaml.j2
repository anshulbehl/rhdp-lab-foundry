---
# Firewall rules for {{ lab_name }}
# Generated by Lab Foundry

ingress:
  - ports:
      - 22    # SSH
      - 443   # HTTPS
{% for port in ingress_ports | default([]) %}
      - {{ port }}
{% endfor %}

egress:
  - ports:
      - 53    # DNS
      - 443   # HTTPS outbound
      - 80    # HTTP outbound
{% for port in egress_ports | default([]) %}
      - {{ port }}
{% endfor %}
