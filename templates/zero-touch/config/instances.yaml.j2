---
# Lab: {{ lab_name }}
# Generated by Lab Foundry ({{ blueprint }} blueprint)

{% if virtualmachines is defined %}
virtualmachines:
{% for vm in virtualmachines %}
  - name: {{ vm.name }}
    image: {{ vm.image }}
    memory: {{ vm.memory | default('4Gi') }}
    cores: {{ vm.cores | default(2) }}
    image_size: {{ vm.image_size | default('30Gi') }}
{% if vm.services is defined %}
    services:
{% for svc in vm.services %}
      - name: {{ svc.name }}
        port: {{ svc.port }}
        protocol: {{ svc.protocol | default('TCP') }}
{% endfor %}
{% endif %}
{% if vm.routes is defined %}
    routes:
{% for route in vm.routes %}
      - name: {{ route.name }}
        service: {{ route.service }}
        targetPort: {{ route.target_port }}
        tls_termination: {{ route.tls | default('Edge') }}
{% endfor %}
{% endif %}
{% if vm.userdata is defined %}
    userdata: |
{{ vm.userdata | indent(6, true) }}
{% endif %}
{% if vm.tags is defined %}
    tags:
{% for key, value in vm.tags.items() %}
      {{ key }}: {{ value }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

{% if containers is defined %}
containers:
{% for container in containers %}
  - name: {{ container.name }}
    image: {{ container.image }}
{% if container.ports is defined %}
    ports:
{% for port in container.ports %}
      - containerPort: {{ port }}
{% endfor %}
{% endif %}
{% if container.environment is defined %}
    environment:
{% for key, value in container.environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if container.volumes is defined %}
    volumeMounts:
{% for vol in container.volumes %}
      - name: {{ vol.name }}
        mountPath: {{ vol.mount_path }}
{% endfor %}
    volumes:
{% for vol in container.volumes %}
      - name: {{ vol.name }}
        emptyDir: {}
{% endfor %}
{% endif %}
{% if container.services is defined %}
    services:
{% for svc in container.services %}
      - name: {{ svc.name }}
        port: {{ svc.port }}
        protocol: {{ svc.protocol | default('TCP') }}
{% endfor %}
{% endif %}
{% if container.routes is defined %}
    routes:
{% for route in container.routes %}
      - name: {{ route.name }}
        service: {{ route.service }}
        targetPort: {{ route.target_port }}
        tls_termination: {{ route.tls | default('Edge') }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
