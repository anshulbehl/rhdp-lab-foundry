#!/bin/bash
# AAP post-install configuration for {{ lab_name }}
# Generated by Lab Foundry
#
# Waits for AAP readiness, generates an OAuth token, then configures
# credentials, projects, inventories, job templates, workflows, and RBAC.
#
# Patterns from:
# - zt-ans-bu-zta-aap (tag-driven playbook approach)
# - zt-ans-bu-hashi-aap (inline playbook approach)
set -euo pipefail

LOG_PREFIX="[aap-configure]"
log() { echo "${LOG_PREFIX} $*"; }

AAP_HOST="{{ aap_host | default('https://control.' + lab_domain) }}"
AAP_USER="{{ aap_user | default('admin') }}"
AAP_PASS="{{ aap_pass | default('ansible123!') }}"
PLAYBOOK_DIR="{{ aap_playbook_dir | default('/tmp/lab-automation') }}"

export ANSIBLE_LOCALHOST_WARNING=False
export ANSIBLE_INVENTORY_UNPARSED_WARNING=False

# ============================================================
# Step 1: Wait for AAP controller readiness
# ============================================================
log "Waiting for AAP controller at ${AAP_HOST}..."
for i in $(seq 1 60); do
    CODE=$(curl -sk -o /dev/null -w "%{http_code}" \
        "${AAP_HOST}/api/controller/v2/ping/" \
        -u "${AAP_USER}:${AAP_PASS}" 2>/dev/null)
    if [ "$CODE" = "200" ]; then
        log "  AAP ready (attempt $i)"
        break
    fi
    if [ "$i" = "60" ]; then
        log "FATAL: AAP not ready after 60 attempts"
        exit 1
    fi
    log "  waiting... (attempt $i, HTTP $CODE)"
    sleep 10
done

# ============================================================
# Step 2: Generate OAuth token
# ============================================================
log "Generating AAP OAuth token..."
CONTROLLER_OAUTH_TOKEN=$(curl -sk -X POST \
    "${AAP_HOST}/api/controller/v2/tokens/" \
    -H "Content-Type: application/json" \
    -u "${AAP_USER}:${AAP_PASS}" \
    -d '{"description":"lab-foundry-setup","application":null,"scope":"write"}' | \
    python3 -c "import sys,json; print(json.load(sys.stdin)['token'])" 2>/dev/null)

if [ -z "${CONTROLLER_OAUTH_TOKEN}" ]; then
    log "FATAL: Failed to generate AAP OAuth token"
    exit 1
fi
log "  Token generated OK"
export CONTROLLER_OAUTH_TOKEN

TOKEN_VAR="controller_oauth_token=${CONTROLLER_OAUTH_TOKEN}"
{% if aap_extra_vars is defined %}
{% for key, value in aap_extra_vars.items() %}
EXTRA_{{ key | upper }}="{{ value }}"
{% endfor %}
{% endif %}

# ============================================================
# Step 3: Install required collections
# ============================================================
log "Ensuring ansible.controller collection..."
if ! ansible-galaxy collection list 2>/dev/null | grep -q "ansible.controller"; then
    ansible-galaxy collection install ansible.controller 2>/dev/null || {
        log "  ansible.controller not available; symlinking awx.awx as fallback"
        if ansible-galaxy collection list 2>/dev/null | grep -q "awx.awx"; then
            mkdir -p ~/.ansible/collections/ansible_collections/ansible
            ln -sfn ~/.ansible/collections/ansible_collections/awx/awx \
                    ~/.ansible/collections/ansible_collections/ansible/controller
        else
            ansible-galaxy collection install awx.awx
            mkdir -p ~/.ansible/collections/ansible_collections/ansible
            ln -sfn ~/.ansible/collections/ansible_collections/awx/awx \
                    ~/.ansible/collections/ansible_collections/ansible/controller
        fi
    }
fi
log "  Collection ready"

cd "${PLAYBOOK_DIR}" || { log "FATAL: Cannot cd to ${PLAYBOOK_DIR}"; exit 1; }

# ============================================================
# Step 4: Configure AAP resources
#
# Edit the sections below to match your lab's requirements.
# Each section is independent and can be run selectively.
# ============================================================

{% if aap_credentials is defined %}
# --- Credentials ---
log "Configuring credentials..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-credentials.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_execution_environments is defined %}
# --- Execution Environments ---
log "Configuring execution environments..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-ee.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_projects is defined %}
# --- Projects ---
log "Configuring projects..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-project.yml \
    --tags project \
    -e "${TOKEN_VAR}"

# Wait for project sync to complete
log "  Waiting for project sync..."
sleep 15
{% endif %}

{% if aap_inventories is defined %}
# --- Inventories ---
log "Configuring inventories..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-inventory.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_templates is defined %}
# --- Job Templates ---
log "Configuring job templates..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-templates.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_workflows is defined %}
# --- Workflow Job Templates ---
log "Configuring workflows..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-workflows.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_teams is defined %}
# --- RBAC (Teams and Role Assignments) ---
log "Configuring RBAC..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-rbac.yml \
    -e "${TOKEN_VAR}"
{% endif %}

{% if aap_eda is defined %}
# --- Event-Driven Ansible ---
log "Configuring EDA..."
ansible-playbook -i inventory/hosts.ini setup/configure-aap-eda.yml \
    -e "${TOKEN_VAR}"
{% endif %}

# ============================================================
# Summary
# ============================================================
log "AAP configuration complete."
log "  Controller: ${AAP_HOST}"
log "  User: ${AAP_USER}"
{% if aap_credentials is defined %}
log "  Credentials: configured"
{% endif %}
{% if aap_projects is defined %}
log "  Projects: configured"
{% endif %}
{% if aap_templates is defined %}
log "  Job Templates: configured"
{% endif %}
{% if aap_workflows is defined %}
log "  Workflows: configured"
{% endif %}
{% if aap_eda is defined %}
log "  EDA: configured"
{% endif %}
