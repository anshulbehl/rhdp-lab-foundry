#!/bin/bash
# EDA configuration for {{ lab_name }}
# Generated by Lab Foundry
#
# Configures Event-Driven Ansible components in AAP:
# - EDA project (git repo containing rulebooks)
# - Decision environment
# - Event stream with credentials
# - Rulebook activation
#
# Requires: CONTROLLER_OAUTH_TOKEN set by setup-aap-configure.sh
set -euo pipefail

LOG_PREFIX="[eda-configure]"
log() { echo "${LOG_PREFIX} $*"; }

AAP_HOST="{{ aap_host | default('https://control.' + lab_domain) }}"
AAP_USER="{{ aap_user | default('admin') }}"
AAP_PASS="{{ aap_pass | default('ansible123!') }}"

# Use existing token or generate one
if [ -z "${CONTROLLER_OAUTH_TOKEN:-}" ]; then
    log "Generating AAP OAuth token for EDA configuration..."
    CONTROLLER_OAUTH_TOKEN=$(curl -sk -X POST \
        "${AAP_HOST}/api/controller/v2/tokens/" \
        -H "Content-Type: application/json" \
        -u "${AAP_USER}:${AAP_PASS}" \
        -d '{"description":"eda-setup","application":null,"scope":"write"}' | \
        python3 -c "import sys,json; print(json.load(sys.stdin)['token'])" 2>/dev/null)
fi
export CONTROLLER_OAUTH_TOKEN
TOKEN_VAR="controller_oauth_token=${CONTROLLER_OAUTH_TOKEN}"

PLAYBOOK_DIR="{{ aap_playbook_dir | default('/tmp/lab-automation') }}"
cd "${PLAYBOOK_DIR}" || { log "FATAL: Cannot cd to ${PLAYBOOK_DIR}"; exit 1; }

# ============================================================
# EDA Project
# ============================================================
log "Configuring EDA project..."
cat > /tmp/eda-project.yml <<'PLAYBOOK'
---
- name: Configure EDA project
  hosts: localhost
  connection: local
  gather_facts: false
  vars:
    controller_host: "{{ '{{ lookup(\"env\", \"AAP_HOST\") }}' }}"
    controller_oauth_token: "{{ '{{ lookup(\"env\", \"CONTROLLER_OAUTH_TOKEN\") }}' }}"
  tasks:
    - name: Create EDA project
      ansible.controller.project:
        name: "{{ eda_project_name | default(lab_name + ' EDA') }}"
        organization: Default
        scm_type: git
        scm_url: "{{ eda_project_url }}"
{% if eda_project_branch is defined %}
        scm_branch: "{{ eda_project_branch }}"
{% endif %}
        state: present

{% if eda_credential_name is defined %}
    - name: Create EDA event stream credential
      ansible.controller.credential:
        name: "{{ eda_credential_name }}"
        organization: Default
        credential_type: "{{ eda_credential_type | default('Token Event Stream') }}"
        inputs:
          token: "{{ eda_credential_token | default('change-me-token') }}"
        state: present
{% endif %}
PLAYBOOK

AAP_HOST="${AAP_HOST}" ansible-playbook /tmp/eda-project.yml -e "${TOKEN_VAR}"

# ============================================================
# Decision Environment
# ============================================================
{% if eda_decision_env_image is defined %}
log "Configuring decision environment..."
cat > /tmp/eda-de.yml <<'PLAYBOOK'
---
- name: Configure decision environment
  hosts: localhost
  connection: local
  gather_facts: false
  vars:
    controller_host: "{{ '{{ lookup(\"env\", \"AAP_HOST\") }}' }}"
    controller_oauth_token: "{{ '{{ lookup(\"env\", \"CONTROLLER_OAUTH_TOKEN\") }}' }}"
  tasks:
    - name: Create decision environment
      ansible.controller.execution_environment:
        name: "{{ eda_decision_env_name | default(lab_name + ' Decision Environment') }}"
        image: "{{ eda_decision_env_image }}"
        state: present
PLAYBOOK

AAP_HOST="${AAP_HOST}" ansible-playbook /tmp/eda-de.yml -e "${TOKEN_VAR}"
{% endif %}

# ============================================================
# Event Stream
# ============================================================
{% if eda_event_streams is defined %}
log "Configuring event streams..."
{% for stream in eda_event_streams %}
log "  Event stream: {{ stream.name }}"
{% endfor %}
# Event streams are configured via the AAP UI or API.
# Generate the API call for each stream:
{% for stream in eda_event_streams %}
curl -sk -X POST "${AAP_HOST}/api/eda/v1/event-streams/" \
    -H "Authorization: Bearer ${CONTROLLER_OAUTH_TOKEN}" \
    -H "Content-Type: application/json" \
    -d '{
        "name": "{{ stream.name }}",
        "event_stream_type": "{{ stream.type | default('token') }}",
{% if stream.credential is defined %}
        "credential": "{{ stream.credential }}",
{% endif %}
        "organization": 1
    }' || log "  Event stream {{ stream.name }} may already exist"
{% endfor %}
{% endif %}

# ============================================================
# Rulebook Activation
# ============================================================
{% if eda_rulebook_name is defined %}
log "Configuring rulebook activation..."
log "  Rulebook: {{ eda_rulebook_name }}"
log "  Project: {{ eda_project_name | default(lab_name + ' EDA') }}"

# Rulebook activations require the project to be synced first.
# The activation links: project + rulebook + decision environment + event stream.
# This is typically done via the AAP UI after the components above are created.
log "  NOTE: Create rulebook activation via AAP UI:"
log "    Name: {{ eda_activation_name | default(lab_name + ' Events') }}"
log "    Project: {{ eda_project_name | default(lab_name + ' EDA') }}"
log "    Rulebook: {{ eda_rulebook_name }}"
{% if eda_decision_env_name is defined %}
log "    Decision Environment: {{ eda_decision_env_name }}"
{% endif %}
{% if eda_event_streams is defined %}
{% for stream in eda_event_streams %}
log "    Event Stream: {{ stream.name }}"
{% endfor %}
{% endif %}
{% endif %}

log "EDA configuration complete."
