#!/bin/bash
# Central node multi-service configuration for {{ lab_name }}
# Generated by Lab Foundry
#
# This script configures multiple services on a single VM using podman
# containers and systemd units. Each service has an idempotent setup
# block and a readiness check.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG_PREFIX="[central-configure]"

# ============================================================
# Helper functions
# ============================================================

log() { echo "${LOG_PREFIX} $*"; }

retry() {
    local max_attempts="${1}"
    local delay="${2}"
    local desc="${3}"
    shift 3
    for ((i = 1; i <= max_attempts; i++)); do
        log "Attempt $i/$max_attempts: $desc"
        if "$@"; then
            return 0
        fi
        if [ $i -lt $max_attempts ]; then
            log "  Retrying in ${delay}s..."
            sleep "$delay"
        fi
    done
    log "FATAL: Failed after $max_attempts attempts: $desc"
    exit 1
}

wait_for_http() {
    local url="$1"
    local max_retries="${2:-30}"
    local delay="${3:-10}"
    log "Waiting for HTTP 200 at $url..."
    for ((i = 1; i <= max_retries; i++)); do
        CODE=$(curl -sk -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")
        if [[ "$CODE" =~ ^(200|301|302|401|403)$ ]]; then
            log "  Ready (attempt $i, HTTP $CODE)"
            return 0
        fi
        log "  waiting... (attempt $i, HTTP $CODE)"
        sleep "$delay"
    done
    log "FATAL: $url not ready after $max_retries attempts"
    exit 1
}

podman_ensure() {
    local name="$1"
    shift
    if podman container exists "$name" 2>/dev/null; then
        log "Stopping existing container: $name"
        podman stop "$name" 2>/dev/null || true
        systemctl stop "container-${name}" 2>/dev/null || true
        systemctl kill "container-${name}" 2>/dev/null || true
        podman rm --force "$name" 2>/dev/null || true
    fi
    log "Creating container: $name"
    podman create --name "$name" --restart=always "$@"
    podman generate systemd --name "$name" --new --files 2>/dev/null || true
    if [ -f "/etc/systemd/system/container-${name}.service" ]; then
        sed -i "/^PIDFile/d" "/etc/systemd/system/container-${name}.service"
        systemctl daemon-reload
    fi
    systemctl start "container-${name}" 2>/dev/null || podman start "$name"
    log "  Container $name started"
}

# ============================================================
# Service configuration
# ============================================================
{% for svc in central_services %}

# --- {{ svc.name }} ---
log "Configuring {{ svc.name }}..."
{% if svc.type == 'podman' %}
podman_ensure "{{ svc.name }}" \
{% for port in svc.ports %}
    -p {{ port }} \
{% endfor %}
{% for key, value in (svc.environment | default({})).items() %}
    -e {{ key }}="{{ value }}" \
{% endfor %}
{% if svc.volumes is defined %}
{% for vol in svc.volumes %}
    -v {{ vol }} \
{% endfor %}
{% endif %}
    {{ svc.image }}{% if svc.command is defined %} {{ svc.command }}{% endif %}

{% elif svc.type == 'systemd' %}
if systemctl is-active --quiet {{ svc.name }}; then
    log "  SKIP: {{ svc.name }} already running"
else
    log "  Starting {{ svc.name }}..."
    systemctl enable --now {{ svc.name }}
fi
{% endif %}
{% if svc.readiness_check is defined %}

# Readiness check for {{ svc.name }}
{% if svc.readiness_check.startswith('http') %}
wait_for_http "{{ svc.readiness_check }}" {{ svc.readiness_retries | default(30) }} {{ svc.readiness_delay | default(10) }}
{% else %}
retry {{ svc.readiness_retries | default(10) }} {{ svc.readiness_delay | default(5) }} "{{ svc.name }} readiness" {{ svc.readiness_check }}
{% endif %}
{% endif %}
{% endfor %}

# ============================================================
# Final status
# ============================================================
log "Central node configuration complete."
log "Services configured: {{ central_services | map(attribute='name') | join(', ') }}"
